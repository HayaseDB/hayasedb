{
  "$schema": "https://turborepo.dev/schema.v2.json",
  "ui": "stream",
  "globalDependencies": [".nvmrc", "bunfig.toml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^prepare"],
      "inputs": ["$TURBO_DEFAULT$", "!.nuxt/**", "!.output/**", "!dist/**"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "prepare": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!.nuxt/**"],
      "outputs": [".nuxt/**"]
    },
    "check-types": {
      "dependsOn": ["^build", "prepare"]
    },
    "lint": {
      "dependsOn": ["prepare"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false,
      "dependsOn": ["^build"],
      "passThroughEnv": ["DATABASE_URL", "POSTGRES_*"]
    },
    "db:migrate": {
      "cache": false,
      "dependsOn": ["^build"],
      "passThroughEnv": ["DATABASE_URL", "POSTGRES_*"]
    },
    "seed:demo": {
      "cache": false,
      "dependsOn": ["^build"],
      "passThroughEnv": ["DATABASE_URL", "POSTGRES_*", "MINIO_*", "SEED_COUNT"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"],
      "passThroughEnv": [
        "NODE_ENV",
        "DATABASE_URL",
        "POSTGRES_*",
        "REDIS_*",
        "API_*",
        "AUTH_*",
        "WEB_*",
        "ADMIN_*",
        "MINIO_*",
        "MAIL_*",
        "MAILPIT_*",
        "GITHUB_*",
        "DISCORD_*",
        "NUXT_*",
        "NITRO_*"
      ]
    }
  }
}
