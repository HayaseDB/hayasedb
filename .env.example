# HayaseDB Environment Configuration

# Application Stack
APP_STACK_NAME=staging

# Docker image tags
API_IMAGE_TAG=latest
WEB_IMAGE_TAG=latest

# Domain Configuration
API_DOMAIN=api.hayasedb.com
WEB_DOMAIN=hayasedb.com
CDN_DOMAIN=cdn.hayasedb.com
MINIO_DOMAIN=minio.hayasedb.com
PGADMIN_DOMAIN=database.hayasedb.com

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@hayasedb.com
PGADMIN_DEFAULT_PASSWORD=change-me-to-a-secure-password

# API
API_PORT=3000
API_LOG_LEVEL=log
API_WEB_URL=https://hayasedb.com
API_BASE_URL=https://api.hayasedb.com
API_ENVIRONMENT=development
API_DATABASE_HOST=postgres
API_DATABASE_PORT=5432
API_DATABASE_NAME=hayasedb
API_DATABASE_USER=postgres
API_DATABASE_PASSWORD=postgres
API_DATABASE_SYNCHRONIZE=false
API_DATABASE_LOGGING=false
API_STORAGE_PROVIDER=minio
API_STORAGE_BUCKET=hayasedb
API_CDN_URL=https://cdn.hayasedb.com
# Local Storage (when API_STORAGE_PROVIDER=local)
# API_STORAGE_LOCAL_PATH=./uploads
# API_STORAGE_LOCAL_BASE_URL=http://localhost:3000/storage
API_MINIO_HOST=minio
API_MINIO_PORT=9000
API_MINIO_USER=minioadmin
API_MINIO_PASSWORD=minioadmin
API_MINIO_USE_SSL=false
API_REDIS_HOST=redis
API_REDIS_PORT=6379
API_REDIS_DB=0
API_JWT_SECRET=change-me-to-a-secure-secret
API_JWT_EXPIRES_IN=1h
API_JWT_REFRESH_SECRET=change-me-to-a-secure-secret
API_JWT_REFRESH_EXPIRES_IN=7d
API_MAIL_PROVIDER=smtp
API_MAIL_FROM_NAME=HayaseDB
API_MAIL_FROM_ADDRESS=noreply@hayasedb.com
API_MAIL_VERIFY_CONNECTION=false
API_MAIL_SMTP_HOST=localhost
API_MAIL_SMTP_PORT=1025
API_MAIL_SMTP_SECURE=false
API_MAIL_SMTP_USER=
API_MAIL_SMTP_PASS=
# Resend Provider (when API_MAIL_PROVIDER=resend)
# API_MAIL_RESEND_KEY=re_xxxxxxxxxxxx
API_MAIL_QUEUE_ENABLED=true
API_MAIL_QUEUE_MAX_RETRIES=5
API_MAIL_QUEUE_INITIAL_DELAY=1000
API_MAIL_QUEUE_RATE_LIMIT_MAX=2
API_MAIL_QUEUE_CONCURRENCY=1
API_QUEUE_DEFAULT_RETRIES=5
API_QUEUE_DEFAULT_BACKOFF_DELAY=1000
API_SWAGGER_ENABLED=true
API_SWAGGER_PATH=docs

# Web Frontend
WEB_API_URL=https://api.hayasedb.com
