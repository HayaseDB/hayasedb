NODE_ENV=development

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hayase
POSTGRES_PASSWORD=hayase
POSTGRES_DB=hayasedb

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App connection strings
DATABASE_URL=postgres://hayase:hayase@localhost:5432/hayasedb

# API
API_HOST=0.0.0.0
API_PORT=3000
API_PUBLIC_URL=http://localhost:3000

# Auth
AUTH_SECRET=CHANGEME
AUTH_BASE_URL=http://localhost:3000
AUTH_TRUSTED_ORIGINS=http://localhost:3001,http://localhost:3002

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# S3
S3_ENDPOINT=http://localhost:3900
S3_PORT=3900
S3_ADMIN_PORT=3903
S3_REGION=garage
S3_ACCESS_KEY=CHANGEME
S3_SECRET_KEY=CHANGEME
S3_BUCKET_PUBLIC=media-public
S3_BUCKET_ORIGINAL=media-original
GARAGE_RPC_SECRET=CHANGEME

# Mail
MAIL_DRIVER=smtp
MAIL_FROM='Hayasedb <no-reply@hayasedb.com>'
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAILPIT_UI_PORT=8025
# RESEND_API_KEY=

# Web / Admin
NUXT_PUBLIC_API_URL=http://localhost:3000
WEB_PORT=3001
ADMIN_PORT=3002

# Deployment
TAG=latest
API_DOMAIN=api.hayasedb.com
WEB_DOMAIN=hayasedb.com
ADMIN_DOMAIN=admin.hayasedb.com

