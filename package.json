{
  "name": "hayasedb",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "5.9.3",
      "zod": "4.4.3",
      "drizzle-orm": "0.45.2",
      "drizzle-kit": "0.31.10",
      "postgres": "3.4.9",
      "better-auth": "1.6.23",
      "@orpc/contract": "2.0.0-beta.11",
      "@orpc/server": "2.0.0-beta.11",
      "@orpc/client": "2.0.0-beta.11",
      "@orpc/nest": "2.0.0-beta.11",
      "@orpc/openapi": "2.0.0-beta.11",
      "@orpc/zod": "2.0.0-beta.11",
      "@orpc/tanstack-query": "2.0.0-beta.11",
      "tsdown": "0.22.3",
      "tsx": "4.23.0",
      "dotenv": "17.2.3"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "predev": "bun run infra:up",
    "dev": "turbo run dev",
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate --filter=@hayasedb/db",
    "db:migrate": "turbo run db:migrate --filter=@hayasedb/db",
    "db:studio": "bun --filter @hayasedb/db db:studio",
    "auth:generate": "bun --filter @hayasedb/auth auth:generate",
    "changeset": "changeset",
    "version": "changeset version && bun install --lockfile-only",
    "tag": "changeset tag",
    "changelog": "changeset status --verbose"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "10.1.8",
    "fkill-cli": "9.0.0",
    "jiti": "^2.4.2",
    "prettier": "3.9.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "turbo": "^2.10.3"
  }
}
