{
  "name": "@hayasedb/shared",
  "version": "0.0.1",
  "description": "Shared types, enums, and interfaces for HayaseDB",
  "author": "HayaseDB",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HayaseDB/hayasedb.git",
    "directory": "packages/shared"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "pnpm format && pnpm lint:fix && pnpm typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.0"
  }
}
