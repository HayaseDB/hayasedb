{
  "name": "@hayasedb/contract",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/base.mjs",
    "**/base.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@hayasedb/domain": "workspace:*",
    "@orpc/contract": "catalog:",
    "@orpc/openapi": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@hayasedb/eslint-config": "workspace:*",
    "@hayasedb/typescript-config": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
