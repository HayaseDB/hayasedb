{
  "name": "@hayasedb/sdk",
  "version": "0.0.1",
  "description": "Official SDK for the HayaseDB API",
  "author": "HayaseDB",
  "type": "module",
  "private": false,
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HayaseDB/hayasedb.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/HayaseDB/hayasedb/tree/main/packages/sdk",
  "bugs": {
    "url": "https://github.com/HayaseDB/hayasedb/issues"
  },
  "keywords": ["hayasedb", "anime", "api", "sdk", "client"],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "pnpm format && pnpm lint:fix && pnpm typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hayasedb/shared": "workspace:*",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
