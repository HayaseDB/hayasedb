{
  "name": "@hayasedb/mail",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "email": "email dev --dir ./emails --port 3005",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@react-email/components": "catalog:",
    "@react-email/render": "catalog:",
    "nodemailer": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "resend": "catalog:"
  },
  "devDependencies": {
    "@hayasedb/eslint-config": "workspace:*",
    "@hayasedb/typescript-config": "workspace:*",
    "@react-email/ui": "catalog:",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "catalog:",
    "@types/react": "catalog:",
    "react-email": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
