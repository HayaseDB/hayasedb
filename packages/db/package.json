{
  "name": "@hayasedb/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./dist/schema/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "files": [
    "dist",
    "drizzle"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check --dialect=postgresql --out=./drizzle",
    "db:migrate": "tsx src/migrate-cli.ts",
    "db:studio": "drizzle-kit studio",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@hayasedb/domain": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@hayasedb/eslint-config": "workspace:*",
    "@hayasedb/typescript-config": "workspace:*",
    "@types/node": "^22.20.1",
    "dotenv": "catalog:",
    "drizzle-kit": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
