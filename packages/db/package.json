{
  "name": "@hayasedb/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./dist/schema/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate-cli.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hayasedb/domain": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@hayasedb/config": "workspace:*",
    "@types/node": "^22.10.0",
    "dotenv": "catalog:",
    "drizzle-kit": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
